# Shell aliases
# Cross-platform with tool availability checks

# ==============================================================================
# File listing (lsd if available, otherwise standard ls)
# ==============================================================================

if command -v lsd &>/dev/null; then
  alias ls='lsd -A'
  alias ll='lsd -lA'
  alias la='lsd -a'
else
  alias ls='ls -A'
  alias ll='ls -lA'
  alias la='ls -a'
fi

# ==============================================================================
# Directory navigation
# ==============================================================================

alias tree='tree -a -I .git'

# ==============================================================================
# Kubernetes (kubectl must be available)
# ==============================================================================

if command -v kubectl &>/dev/null; then
  alias k="kubectl"
fi

# ==============================================================================
# z4h utilities
# ==============================================================================

alias clear=z4h-clear-screen-soft-bottom
