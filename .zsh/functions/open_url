# Function to open URL in browser (works locally and in remote SSH)
open_url() {
  local url="$1"

  if [[ -n "$BROWSER" ]]; then
    "$BROWSER" "$url"
  elif [[ "$OSTYPE" == "darwin"* ]]; then
    open "$url"
  else
    # Auto-detect Cursor or VS Code browser helper for remote SSH sessions
    local helper
    helper=$(ls -t \
      ~/.cursor-server/bin/linux-x64/*/bin/helpers/browser.sh \
      ~/.vscode-server/cli/servers/Stable-*/server/bin/helpers/browser.sh \
      2>/dev/null | head -1)
    if [[ -n "$helper" ]]; then
      if [[ -z "$VSCODE_IPC_HOOK_CLI" ]]; then
        local sock
        sock=$(ls -t /run/user/$(id -u)/vscode-ipc-*.sock 2>/dev/null | head -1)
        if [[ -n "$sock" ]]; then
          VSCODE_IPC_HOOK_CLI="$sock" "$helper" "$url"
        else
          echo "Could not find IDE IPC socket. Open this URL manually:"
          echo "$url"
          return 1
        fi
      else
        "$helper" "$url"
      fi
    elif command -v xdg-open &> /dev/null; then
      xdg-open "$url"
    else
      echo "No support for opening URL: $url"
      return 1
    fi
  fi
}
