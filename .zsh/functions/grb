# grb - Git rebase all branches (or filtered) against databricks/master
# Usage: grb [filter]
#   If filter is provided, only branches matching the filter are rebased

function grb() {
  local filter=$1
  local command="git for-each-ref --sort=-committerdate --format='%(refname:short)' refs/heads/"

  if [[ -n "$filter" ]]; then
    command="$command | grep $filter"
  fi

  local branches=($(eval $command))
  for branch in $branches; do
    git switch "$branch"
    git fetch databricks master
    git rebase databricks/master
    git pp origin --force
  done
}

grb "$@"
